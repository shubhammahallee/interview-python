#Move all zeros to end



# Collect non-zeros, then fill zeros at end
num = [1, 0, 3, 0, 5, 0]

non_zeros = []
zero_count = 0

for i in range(len(num)):
    if num[i] != 0:
        non_zeros.append(num[i])
    else:
        zero_count = zero_count + 1

result = non_zeros            # start with non-zeros
for i in range(zero_count):   # add zeros at the end
    result.append(0)

print("Result:", result)

# Input : [1, 0, 3, 0, 5, 0]
# Output: [1, 3, 5, 0, 0, 0]
