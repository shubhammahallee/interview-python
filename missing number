#Find missing number in array

# Use the formula: sum(1..N) - actual_sum = missing
arr = [1, 2, 4, 5, 6]   # 3 is missing
n = len(arr) + 1           # total numbers should be n

expected_sum = n * (n + 1) // 2  # formula, no loop needed

actual_sum = 0
for i in range(len(arr)):
    actual_sum = actual_sum + arr[i]

missing = expected_sum - actual_sum

print("Missing number:", missing)

# Input : [1, 2, 4, 5, 6]
# Output: 3
